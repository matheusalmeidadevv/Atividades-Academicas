
public class Guerreiro extends Entidade{
	
	private int vida = 0, mana = 0, forca = 0;
	
	public Guerreiro(String nome, int nivel, int vida, int mana, int forca) {
		
		super(nome, nivel);
		this.vida = vida;
		this.mana = mana;
		this.forca = forca;
		
	}
	
	public String Atributosfisicos() {
		
		return "\nGuerreiro Ficha:\n Vida = " + vida + "\n Mana = " + mana + "\n Força = " + forca;
		
	}
	
}
