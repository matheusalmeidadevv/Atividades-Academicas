
public class Normal extends Ingresso implements IValor{
	
	public Normal(int numIngressos, double vlIngresso, String tipoIngresso) {
		super(numIngressos, vlIngresso, tipoIngresso);
		
	}
	
	@Override
	public String imprimeValor() {
		
		return "O valor do Ingresso Normal é: " + vlIngresso;
	}
	
	@Override
	public String toString() {
		
		return "======Status do Ingresso Normal====== \n\nNumero de Ingressos: " + this.numIngressos + "\nTipo do ingresso: " + this.tipoIngresso;
		
	}
	
}
